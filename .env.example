# Shopify App credentials
# Get these from your Partner Dashboard → Apps → Your App → Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Your app's public URL (use ngrok URL during development)
# Example: https://abc123.ngrok.io
SHOPIFY_APP_URL=https://your-app-url.fly.dev

# App scopes (don't change this)
SCOPES=read_products,read_content,read_themes,read_script_tags,read_metafields,read_online_store_pages

# Database (SQLite for dev, PostgreSQL for production)
# For development:
DATABASE_URL="file:./dev.sqlite"
# For production (Fly.io with PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
