{
  "version": 2,
  "buildCommand": "prisma generate && npm run build",
  "outputDirectory": "build/client",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)$",
      "dest": "/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
